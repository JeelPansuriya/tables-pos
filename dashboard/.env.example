# Copy to .env.local for local dev, and set these as Environment Variables in Vercel.
# Both are safe to expose to the browser (the anon key is public by design;
# Row-Level Security + Supabase Auth login control what a signed-in user can read).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Table prefix used by the POS (matches supabase_table_prefix in the app, default v2_).
VITE_TABLE_PREFIX=v2_
# IANA timezone the restaurant operates in — used to group sales by business day.
VITE_TIMEZONE=Asia/Kolkata
