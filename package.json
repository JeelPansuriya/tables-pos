{
  "name": "tables-pos",
  "version": "0.2.5",
  "description": "Restaurant table-based POS — dine-in, takeaway, and pre-orders",
  "productName": "Girr Kathiyawadi Tables",
  "repository": {
    "type": "git",
    "url": "https://github.com/JeelPansuriya/tables-pos.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:unpacked": "tsc -b && vite build && electron-builder --dir",
    "release": "tsc -b && vite build && electron-builder --publish always",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "electron-pos-printer": "^1.4.0",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.girrkathiyawadi.tables",
    "productName": "Girr Kathiyawadi Tables",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "JeelPansuriya",
        "repo": "tables-pos",
        "releaseType": "release"
      }
    ]
  }
}
